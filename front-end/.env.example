# GitHub API
GITHUB_USERNAME=your_github_username

# Site URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Backend Azure Function URL (local dev — Digital Twin chat)
# Local:      http://localhost:7071
# Production: leave unset — SWA proxies /api/* to linked Function App
NEXT_PUBLIC_BACKEND_URL=http://localhost:7071

# Contact form — Web3Forms (free, works on static exports / Azure SWA)
# Get your access key at https://web3forms.com — just enter your email, no sign-up required
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key
